{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default"
    }
  ],
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "firestore.rules",
      "README.md",
      "deploy-precompile.js"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
